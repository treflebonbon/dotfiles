#!/usr/bin/env bash
# Codex managed AGENTS hash: {{ include "private_dot_config/codex/AGENTS.md" | sha256sum }}
set -euo pipefail

managed_agents="$HOME/.config/codex/AGENTS.md"

codex_home="${CODEX_HOME:-$HOME/.codex}"
codex_agents="$codex_home/AGENTS.md"

if [ ! -f "$managed_agents" ]; then
  echo "WARN: Codex managed AGENTS not found: $managed_agents" >&2
  exit 0
fi

mkdir -p "$codex_home"
tmp="$(mktemp "$codex_agents.tmp.XXXXXX")"
trap 'rm -f "$tmp"' EXIT

cp "$managed_agents" "$tmp"
chmod 600 "$tmp"
mv "$tmp" "$codex_agents"
trap - EXIT
