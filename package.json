{
  "name": "treflebonbon-dotfiles",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "bun install --frozen-lockfile && bats tests/",
    "claude:yolo": "claude --permission-mode bypassPermissions",
    "claude:auto": "claude --permission-mode auto",
    "codex:yolo": "codex --yolo",
