#!/usr/bin/env bash
set -euo pipefail

skills_dir="${HOME}/.claude/skills"
codex_home="${CODEX_HOME:-$HOME/.codex}"

# CODEX_HOME が .codex 以外に明示指定されていればそれを追加 cleanup 対象にする。
# 未指定なら Codex Desktop (.codex-app) の存在チェックで追加ホームを決める。
# run_onchange_after_codex-{config,hooks}.sh.tmpl の dual-home 判定と設計思想を統一。
extra_codex_home=""
if [ "$codex_home" != "$HOME/.codex" ]; then
  extra_codex_home="$codex_home"
elif [ -d "$HOME/.codex-app" ]; then
  extra_codex_home="$HOME/.codex-app"
fi

# chezmoi 配布のローカル skill（apm 非管理）。real-dir wipe から除外する。
# run_onchange_after_deploy-local-skills.sh.tmpl の local_skills=() と一致させること。
preserve_local_skills=(
  to-pr
  to-worktree
  dogfood-to-issues
  harness-feedback
  marp
  md-agents-review
  md-claude-review
  rop
  worktree-gc
)

is_preserved_local_skill() {
  local name="$1" p
  for p in "${preserve_local_skills[@]}"; do
    [ "$name" = "$p" ] && return 0
  done
  return 1
}

cleanup_repo_local_apm_targets() {
  # chezmoi が script 実行時に渡す CHEZMOI_SOURCE_DIR で source を解決する
  # (ghq checkout 等 init --source の場所に追従。fallback は旧デフォルトパス)
  local repo="${CHEZMOI_SOURCE_DIR:-${HOME}/.local/share/chezmoi}"
  [ -d "$repo" ] || return 0

  local removed=0
  local entry
  for entry in \
    "$repo/.agents" \
    "$repo/.codex/agents" \
    "$repo/.codex/hooks.json" \
    "$repo/.codex/skills" \
    "$repo/.claude/agents" \
    "$repo/.claude/commands" \
    "$repo/.claude/hooks" \
    "$repo/.claude/skills" \
    "$repo/.claude/apm-hooks.json"; do
    [ -e "$entry" ] || [ -L "$entry" ] || continue

    if mountpoint -q "$entry"; then
      printf 'orphan-claude-skills: skipping mounted repo-local APM target %s\n' "$entry" >&2
      continue
    fi

    rm -rf -- "$entry"
    removed=$((removed + 1))
  done

  if [ "$removed" -gt 0 ]; then
    printf 'orphan-claude-skills: removed %d repo-local APM deploy targets from %s\n' \
      "$removed" "$repo" >&2
  fi
}

cleanup_repo_local_apm_targets

if [ -d "$skills_dir" ]; then
  removed=0
  while IFS= read -r -d '' entry; do
    if is_preserved_local_skill "$(basename "$entry")"; then
      continue
    fi
    rm -rf -- "$entry"
    removed=$((removed + 1))
  done < <(find "$skills_dir" -mindepth 1 -maxdepth 1 -type d -print0)

  if [ "$removed" -gt 0 ]; then
    printf 'orphan-claude-skills: removed %d real directory entries from %s\n' \
      "$removed" "$skills_dir" >&2
  fi
fi

# Symlink 化石の常時除去:
# APM_LEGACY_SKILL_PATHS=1 で apm が ~/.claude/skills/ や ~/.codex/skills/ に
# real directory を deploy する際、symlink が残っていると
# "Skill destination is a symlink -- refusing to deploy" で失敗する。
#
# 以下のいずれかに該当する symlink を除去 (narrow に絞り、ユーザー作成の
# 正当な symlink には触らない):
#   - target が /nix/store/ 配下 (旧 ai.nix shellHook の nix-store 直接参照)
#   - target が ../../.agents/skills/ 配下 (旧 ai.nix の companion 経由)
#   - dangling (target が存在しない壊れた symlink)
#
# 過去は ~/.agents/skills/.managed-by-ai-nix marker 依存だったが、現 ai.nix が
# marker を作らないため発火せず symlink 残骸が永遠に放置される問題への対応。
# 削除した symlink は target 込みで stderr に出力 (発生源調査の forensic 用途)。

cleanup_symlinks() {
  local dir="$1"
  [ -d "$dir" ] || return 0

  local removed=0
  while IFS= read -r -d '' link; do
    local target
    target=$(readlink -- "$link" 2>/dev/null || true)
    local should_remove=0
    case "$target" in
      /nix/store/* | ../../.agents/skills/*)
        should_remove=1
        ;;
      *)
        if [ ! -e "$link" ]; then
          should_remove=1
        fi
        ;;
    esac
    if [ "$should_remove" -eq 1 ]; then
      printf 'orphan-claude-skills: removing %s -> %s\n' "$link" "$target" >&2
      rm -f -- "$link"
      removed=$((removed + 1))
    fi
  done < <(find "$dir" -mindepth 1 -maxdepth 1 -type l -print0)

  if [ "$removed" -gt 0 ]; then
    printf 'orphan-claude-skills: removed %d symlinks from %s\n' \
      "$removed" "$dir" >&2
  fi
}

cleanup_symlinks "${HOME}/.agents/skills"
cleanup_symlinks "$skills_dir"
cleanup_symlinks "${HOME}/.codex/skills"
if [ -n "$extra_codex_home" ]; then
  cleanup_symlinks "$extra_codex_home/skills"
fi
cleanup_symlinks "${HOME}/.copilot/skills"

retired_apm_skills=(
  agent-browser
  autofix
  baseline-ui
  code-review
  dogfood
  fixing-accessibility
  fixing-metadata
  fixing-motion-performance
  grill-me
  uxaudit
  webapp-testing
)

remove_named_skill_entries() {
  local dir="$1"
  local label="$2"
  shift 2
  [ -d "$dir" ] || return 0

  local removed=0
  local skill
  for skill in "$@"; do
    local entry="$dir/$skill"
    if [ -e "$entry" ] || [ -L "$entry" ]; then
      rm -rf -- "$entry"
      removed=$((removed + 1))
    fi
  done

  if [ "$removed" -gt 0 ]; then
    printf "orphan-claude-skills: removed %d retired %s skill entries from %s\n" \
      "$removed" "$label" "$dir" >&2
  fi
}

remove_retired_apm_skill_dirs() {
  remove_named_skill_entries "$1" "apm" "${retired_apm_skills[@]}"
}

remove_retired_apm_skill_dirs "${HOME}/.agents/skills"
remove_retired_apm_skill_dirs "$skills_dir"
remove_retired_apm_skill_dirs "${HOME}/.codex/skills"
if [ -n "$extra_codex_home" ]; then
  remove_retired_apm_skill_dirs "$extra_codex_home/skills"
fi
remove_retired_apm_skill_dirs "${HOME}/.gemini/skills"
remove_retired_apm_skill_dirs "${HOME}/.copilot/skills"

# Codex は ~/.agents/skills を直接読むため、同じローカル skill を
# ~/.codex/skills や runtime CODEX_HOME/skills にも置くと二重表示になる。
# 旧 deploy-local-skills が materialize した real dir はここで撤去する。
remove_named_skill_entries "${HOME}/.codex/skills" "codex local duplicate" "${preserve_local_skills[@]}"
if [ -n "$extra_codex_home" ]; then
  remove_named_skill_entries "$extra_codex_home/skills" "codex local duplicate" "${preserve_local_skills[@]}"
fi

# 化石 marker が残っていれば掃除 (旧 ai.nix の名残、再発防止)
marker="${HOME}/.agents/skills/.managed-by-ai-nix"
if [ -f "$marker" ]; then
  rm -f -- "$marker"
fi
