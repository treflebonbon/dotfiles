{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "test -f \"$HOME/.agents/skills/impeccable/scripts/hook.mjs\" || exit 0; IMPECCABLE_HOOK_QUIET=1 node \"$HOME/.agents/skills/impeccable/scripts/hook.mjs\" || true",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
