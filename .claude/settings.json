{
  "permissions": {
    "allow": ["Skill"],
    "deny": [
      "Read(**/.env*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.pfx)",
      "Read(**/*.p12)",
      "Read(**/credentials.json)",
      "Read(**/credentials.*.json)",
      "Read(**/secret.json)",
      "Read(**/secrets.json)",
      "Read(**/service-account*.json)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Write(**/.env*)",
      "Write(~/.ssh/**)",
      "Bash(rm ~:*)",
      "Bash(rm /:*)",
      "Bash(rm -r ~:*)",
      "Bash(rm -r /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf /:*)",
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(chmod 777:*)",
      "Bash(nc:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)",
      "Bash(gcloud:*)",
      "Bash(aws:*)",
      "Bash(terraform apply:*)",
      "Bash(terraform destroy:*)",
      "Bash(kubectl delete:*)",
      "Bash(gh repo delete:*)",
      "Bash(npm publish:*)",
      "Bash(mix hex.publish:*)"
    ]
  }
}
